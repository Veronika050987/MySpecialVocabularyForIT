@page "/words/edit"
@using Microsoft.EntityFrameworkCore
@using MySpecialVocabularyForIT.Components.Models
@inject IDbContextFactory<MySpecialVocabularyForIT.Data.MySpecialVocabularyForITContext> DbFactory
@inject NavigationManager NavigationManager


<PageTitle>Edit</PageTitle>

<style>
    /*for buttons colors*/
    .custom-purple-button.btn-primary {
        background-color: #8A2BE2;
        border-color: #4B0082;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.08);
        color: white;
    }

        .custom-purple-button.btn-primary:hover {
            background-color: #BA55D3;
            border-color: darkorchid;
            box-shadow: 0 6px 8px rgba(0, 0, 0, 0.15), 0 3px 6px rgba(0, 0, 0, 0.12);
        }

    .custom-purple-button.disabled {
        background-color: #D3D3D3;
        border-color: #D3D3D3;
        color: #6c757d;
    }

    .form-group-margin-top {
        margin-top: 15px;
    }
</style>

<h1>Edit</h1>

<h2>Word</h2>
<hr />
@if (Word is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Word" OnValidSubmit="UpdateWord" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Word.word_id" value="@Word.word_id" />
                <div class="mb-3 blue-label">
                <span class="text-danger">*</span>
                    <label for="word_en" class="form-label">Term in English:</label>
                    <InputText id="word_en" @bind-Value="Word.word_en" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Word.word_en" class="text-danger" />
                </div>
                <div class="mb-3 blue-label">
                <span class="text-danger">*</span>
                    <label for="word_rus" class="form-label">Translation into Russian:</label>
                    <InputText id="word_rus" @bind-Value="Word.word_rus" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Word.word_rus" class="text-danger" />
                </div>
                <div class="mb-3 blue-label">
                    <label for="word_use_case" class="form-label">Use explication:</label>
                    <InputText id="word_use_case" @bind-Value="Word.word_use_case" class="form-control" />
                    <ValidationMessage For="() => Word.word_use_case" class="text-danger" />
                </div>
                @* <div class="mb-3">
                    <label for="photo" class="form-label">photo:</label>
                    <InputText id="photo" @bind-Value="Word.photo" class="form-control" />
                    <ValidationMessage For="() => Word.photo" class="text-danger" />
                </div> *@
                <button type="submit" class="btn btn-primary custom-purple-button">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/words" class="btn btn-primary custom-purple-button form-group-margin-top">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int word_id { get; set; }

    [SupplyParameterFromForm]
    private Word? Word { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Если word_id > 0 (то есть мы редактируем существующий элемент),
        // загружаем его из базы данных.
        if (word_id > 0)
        {
            Word = await context.Words.FindAsync(word_id);
        }
        else
        {
            // Если word_id = 0 (или не передан), создаем новый объект Word.
            // Хотя для страницы редактирования это маловероятно,
            // но такая проверка делает код более надежным.
            Word = new Word();
        }

        // Если Word не найден (например, при редактировании несуществующего ID),
        // перенаправляем на страницу ошибки.
        if (Word is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
        // Важно: Теперь Word загружен и привязан к EditForm.
        // Для IValidatableObject не нужно явно создавать EditContext.
        // Blazor сам позаботится об этом, когда вы используете Model="Word".
    }

    private async Task UpdateWord()
    {
        // Если Валидация прошла успешно (метод OnValidSubmit вызывается только при успехе)
        using var context = DbFactory.CreateDbContext();

        // Проверяем, является ли это новым элементом (word_id == 0) или редактированием
        if (Word!.word_id == 0) // Создание нового
        {
            // Если при создании word_id был 0, и он пришел с формы,
            // то это означает, что мы создаем новую запись.
            // Важно: В этом случае, при создании, word_id будет 0,
            // а при первом сохранении EF Core назначит новый ID.
            context.Words.Add(Word);
        }
        else // Редактирование существующего
        {
            // Прикрепляем объект и устанавливаем состояние Modified.
            // Это важно, чтобы EF Core понял, что нужно обновить существующую запись.
            context.Attach(Word).State = EntityState.Modified;
        }

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException ex)
        {
            // Обработка параллельных обновлений.
            // Проверяем, существует ли еще запись.
            if (!WordExists(Word!.word_id))
            {
                NavigationManager.NavigateTo("notfound");
                return; // Прекращаем выполнение
            }
            else
            {
                // Если запись существует, но произошла ошибка параллельного обновления.
                // Возможно, нужно показать пользователю сообщение об этом.
                // Или перезагрузить данные и попросить пользователя попробовать снова.
                // В данном случае, просто перебрасываем исключение.
                throw;
            }
        }
        catch (Exception ex)
        {
            // Ловим другие возможные ошибки сохранения (например, нарушения ограничений базы данных)
            // Здесь можно добавить логирование или обработку других исключений.
            // Например, если есть уникальные ограничения на уровне БД, которые не были учтены в модели.
            // В реальном приложении, стоит добавить более детальную обработку.
            // В данном случае, мы просто перебрасываем исключение.
            throw;
        }

        // После успешного сохранения перенаправляем на список слов.
        NavigationManager.NavigateTo("/words");
    }

    private bool WordExists(int word_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Words.Any(e => e.word_id == word_id);
    }
}
